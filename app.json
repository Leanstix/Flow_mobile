{
  "expo": {
    "name": "Flow",
    "slug": "flow",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "flow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "icon": "./assets/images/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leanstix.flow",
      "infoPlist": {
        "NSCameraUsageDescription": "Flow uses your camera for video calls and profile media.",
        "NSMicrophoneUsageDescription": "Flow uses your microphone for audio and video calls.",
        "NSPhotoLibraryUsageDescription": "Flow uses your photo library for profile media."
      },
      "bitcode": false
    },
    "android": {
      "package": "com.leanstix.flow",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#0B1437"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1437",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow Flow to use your camera for video calls.",
          "microphonePermission": "Allow Flow to use your microphone for calls."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a67cf300-6ba3-4030-bfbc-7132b25a227a"
      }
    },
    "owner": "leanstix"
  }
}
