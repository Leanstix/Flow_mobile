{
  "name": "flow-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "15.0.1",
    "@expo/ui": "~57.0.7",
    "@hookform/resolvers": "^5.2.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "axios": "^1.13.0",
    "expo": "~57.0.8",
    "expo-constants": "~57.0.7",
    "expo-dev-client": "~57.0.9",
    "expo-device": "~57.0.1",
    "expo-document-picker": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-picker": "~57.0.6",
    "expo-linking": "~57.0.4",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-video": "~57.0.2",
    "expo-web-browser": "~57.0.2",
    "lucide-react-native": "^0.545.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.65.0",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~3.1.0",
    "react-native-reanimated": "4.5.3",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.26.2",
    "react-native-svg": "15.15.5",
    "react-native-video-trim": "8.2.1",
    "react-native-web": "~0.21.0",
    "react-native-webrtc": "124.0.8",
    "react-native-worklets": "0.11.2",
    "zod": "^4.1.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.1",
    "react-test-renderer": "^19.2.3",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "collectCoverageFrom": [
      "src/lib/**/*.{ts,tsx}",
      "src/state/**/*.{ts,tsx}",
      "src/components/ui.tsx",
      "!src/lib/query-client.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 45,
        "functions": 55,
        "lines": 60,
        "statements": 60
      }
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
